import example.Book

model {
    Iterable<Book> bookList
    Integer        bookCount
}

json {
    page     Math.max(0, (params.int('offset', 0) ?: 0).intdiv(params.int('max', 25)))
    pageSize params.int('max', 25)
    total    bookCount
    items    g.render(template: 'book', collection: bookList ?: [], var: 'book')
}
