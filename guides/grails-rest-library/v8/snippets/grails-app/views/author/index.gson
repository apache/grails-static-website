import example.Author

model {
    Iterable<Author> authorList
    Integer          authorCount
}

json {
    page     Math.max(0, (params.int('offset', 0) ?: 0).intdiv(params.int('max', 25)))
    pageSize params.int('max', 25)
    total    authorCount
    items    g.render(template: 'author', collection: authorList ?: [], var: 'author')
}
